PORT=8080
SERVICE_BASE_URL=http://127.0.0.1:8080
TASKS_INLINE=true
DATA_BACKEND=memory
ANALYTICS_SINK_MODE=jsonl
ANALYTICS_JSONL_PATH=tmp/analytics-events.jsonl

GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=europe-west1

TASK_QUEUE_NORMALIZE=vacancy-normalize
TASK_QUEUE_ENRICH=vacancy-enrich
TASK_QUEUE_RATE=vacancy-rate
TASK_QUEUE_NOTIFY=vacancy-notify
TASK_QUEUE_SYNC_SHEETS=sync-sheets
TASK_QUEUE_STATS_REFRESH=stats-refresh

SCRAPE_LEASE_MINUTES=15
DEFAULT_POLL_SECONDS=300
REQUEST_ID_HEADER=x-request-id

ADDON_AUTH_MODE=hmac
ADDON_SHARED_TOKEN=
ADDON_HMAC_SECRET=replace-me
ADDON_HMAC_KEY_ID=default
ADDON_HMAC_MAX_SKEW_SEC=300

TASK_AUTH_MODE=shared-token
INTERNAL_TASK_TOKEN=replace-me
TASK_OIDC_AUDIENCE=
TASK_OIDC_ISSUER=
TASK_OIDC_JWKS_URL=
TASK_OIDC_SERVICE_ACCOUNT_EMAIL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_MODE=fake
TELEGRAM_WEBHOOK_SECRET=replace-me

MINI_APP_SESSION_SECRET=replace-me
MINI_APP_SESSION_TTL_SEC=900
ALLOW_FAKE_TELEGRAM_SESSION=true

GAS_WEBAPP_URL=
RATE_PROVIDER=rule-based

RATE_TARGET_KEYWORDS=backend,node,typescript,gcp,remote
RATE_DENY_KEYWORDS=intern,frontend,designer,qa
